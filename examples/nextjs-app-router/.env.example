# --- server-only (used by app/callback/route.ts; NEVER expose to the browser) ---

# Your aardwin site id (from the aardwin console)
AARDWIN_SITE_ID=
# Server-only secret (NEVER ship to the browser)
AARDWIN_CLIENT_SECRET=
# aardwin api origin (default https://oauth.aard.win; override for local dev)
AARDWIN_API_ORIGIN=http://localhost:4000

# --- browser-public (used by app/login/page.tsx via NEXT_PUBLIC_) ---
# siteId is public; the api origin is needed in the browser only for local dev.
# In production the SDK defaults to https://oauth.aard.win — leave the origin blank there.
# Values mirror the server-only vars above.
NEXT_PUBLIC_AARDWIN_SITE_ID=
NEXT_PUBLIC_AARDWIN_API_ORIGIN=http://localhost:4000
